#!/bin/sh
# dh_installsystemd --no-start also drops the stop-on-removal snippet;
# stop the units explicitly before their files disappear (parity with
# packaging/scripts/preremove.sh in the rpm/apk packages).
set -e
if [ "$1" = remove ] && [ -d /run/systemd/system ]; then
    deb-systemd-invoke stop machine-krb-service.timer machine-krb-service.service >/dev/null 2>&1 || true
fi
#DEBHELPER#
exit 0
